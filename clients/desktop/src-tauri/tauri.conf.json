{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ZeroClaw Desktop",
  "version": "0.1.0",
  "identifier": "com.zeroclaw.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ZeroClaw Desktop",
        "width": 1520,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "capabilities": [
        "default"
      ],
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "targets": "all"
  }
}